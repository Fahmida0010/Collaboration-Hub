generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String?
  createdAt DateTime @default(now())
}


 //announcement
 model Announcement {
  id        String   @id @default(cuid())
  content   String
  isPinned  Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())

  reactions Reaction[]
  comments  Comment[]
}

model Reaction {
  id             String @id @default(cuid())
  emoji          String
  userId         String
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id])
}

model Comment {
  id             String @id @default(cuid())
  text           String
  userId         String
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id])
}