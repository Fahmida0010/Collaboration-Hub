generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. User Model (Auth & Profile)
model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String?
  avatar        String?        // Cloudinary URL thakbe
  workspaces    WorkspaceMember[]
  goals         Goal[]         // Goal owner
  actionItems   ActionItem[]   // Assigned action items
  comments      Comment[]
}

// 2. Workspace Model
model Workspace {
  id          String            @id @default(uuid())
  name        String
  description String?
  accentColor String            @default("#000000")
  members     WorkspaceMember[]
  goals       Goal[]
  announcements Announcement[]
}

// Workspace Member (Role-based access)
model WorkspaceMember {
  id          String    @id @default(uuid())
  role        String    @default("Member") // Admin / Member
  userId      String
  workspaceId String
  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

// 3. Goals & Milestones
model Goal {
  id          String      @id @default(uuid())
  title       String
  status      String      @default("To-Do")
  dueDate     DateTime
  ownerId     String
  workspaceId String
  owner       User        @relation(fields: [ownerId], references: [id])
  workspace   Workspace   @relation(fields: [workspaceId], references: [id])
  milestones  Milestone[]
  actionItems ActionItem[]
}

model Milestone {
  id          String   @id @default(uuid())
  title       String
  progress    Int      @default(0) // 0-100 percentage
  goalId      String
  goal        Goal     @relation(fields: [goalId], references: [id])
}

// 4. Announcements
model Announcement {
  id          String    @id @default(uuid())
  title       String
  content     String    // Rich text
  isPinned    Boolean   @default(false)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  comments    Comment[]
}

// 5. Action Items (Kanban logic)
model ActionItem {
  id          String   @id @default(uuid())
  title       String
  priority    String   @default("Medium")
  status      String   @default("To-Do")
  dueDate     DateTime
  assigneeId  String
  goalId      String?
  assignee    User     @relation(fields: [assigneeId], references: [id])
  goal        Goal?    @relation(fields: [goalId], references: [id])
}

model Comment {
  id             String       @id @default(uuid())
  text           String
  userId         String
  announcementId String
  user           User         @relation(fields: [userId], references: [id])
  announcement   Announcement @relation(fields: [announcementId], references: [id])
}