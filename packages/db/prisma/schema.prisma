generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. User Model (Auth & Profile)
model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String?
  avatar        String?        // Cloudinary URL thakbe
  workspaces    WorkspaceMember[]
  goals         Goal[]         // Goal owner
  actionItems   ActionItem[]   // Assigned action items
  comments      Comment[]
}

// 2. Workspace Model
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?

  memberships Membership[]
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String
  createdAt   DateTime @default(now())

  memberships Membership[]
}

model Membership {
  id          String   @id @default(cuid())
  role        Role     @default(MEMBER)

  userId      String
  workspaceId String

  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
}

enum Role {
  ADMIN
  MEMBER
}

// 3. Goals & Milestones
model Goal {
  id          String      @id @default(cuid())
  title       String
  status      String      // TODO | IN_PROGRESS | DONE
  dueDate     DateTime?
  ownerId     String
  workspaceId String

  milestones  Milestone[]
  activities  Activity[]

  createdAt   DateTime @default(now())
}

model Milestone {
  id        String   @id @default(cuid())
  title     String
  progress  Int      // 0 - 100
  goalId    String

  goal      Goal @relation(fields: [goalId], references: [id])
}

model Activity {
  id        String   @id @default(cuid())
  message   String
  goalId    String

  goal      Goal @relation(fields: [goalId], references: [id])
  createdAt DateTime @default(now())
}

// 4. Announcements
model Announcement {
  id          String    @id @default(uuid())
  title       String
  content     String    // Rich text
  isPinned    Boolean   @default(false)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  comments    Comment[]
}

// 5. Action Items (Kanban logic)
model ActionItem {
  id          String   @id @default(uuid())
  title       String
  priority    String   @default("Medium")
  status      String   @default("To-Do")
  dueDate     DateTime
  assigneeId  String
  goalId      String?
  assignee    User     @relation(fields: [assigneeId], references: [id])
  goal        Goal?    @relation(fields: [goalId], references: [id])
}

model Comment {
  id             String       @id @default(uuid())
  text           String
  userId         String
  announcementId String
  user           User         @relation(fields: [userId], references: [id])
  announcement   Announcement @relation(fields: [announcementId], references: [id])
}